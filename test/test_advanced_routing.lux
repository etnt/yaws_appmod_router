[doc Test advanced routing endpoints]

[global target_host=localhost]
[global target_port=8080]

[shell start_server]
    !make SHELL
    ?1>
    !advanced_routing:start().
    ?"Advanced routing server started on port 8080

# Test API Status endpoint
[shell test_api_status]
    !curl -i -X GET http://$target_host:$target_port/api/status
    ?HTTP/1.1 200 OK
    ?Content-Type: application/json
    ?Access-Control-Allow-Origin: *
    ?{"status":"ok"

# Test GET users endpoint
[shell test_get_users]
    # Test without limit parameter
    !curl -i -X GET http://$target_host:$target_port/api/users
    ?HTTP/1.1 200 OK
    ?Content-Type: application/json
    ?{"users":\[.*\],"limit":10,

    # Test with limit parameter
    !curl -i -X GET "http://$target_host:$target_port/api/users?limit=5"
    ?HTTP/1.1 200 OK
    ?Content-Type: application/json
    ?{"users":\[.*\],"limit":5,

# Test POST user endpoint
[shell test_create_user]
    !curl -i -X POST \
    !     -H "Content-Type: application/json" \
    !     -d '{"name":"Test User","email":"test@example.com"}' \
    !     http://$target_host:$target_port/api/users
    ?HTTP/1.1 200 OK
    ?Content-Type: application/json
    ?{"message":"User created successfully"

# Test GET single user endpoint
[shell test_get_user]
    !curl -i -X GET http://$target_host:$target_port/api/users/1
    ?HTTP/1.1 200 OK
    ?Content-Type: application/json
    ?{"user_id":"1"

# Test PUT user endpoint
[shell test_update_user]
    !curl -i -X PUT \
    !     -H "Content-Type: application/json" \
    !     -d '{"name":"Updated User"}' \
    !     http://$target_host:$target_port/api/users/1
    ?HTTP/1.1 200 OK
    ?Content-Type: application/json
    ?{"message":"User updated successfully"

# Test DELETE user endpoint
[shell test_delete_user]
    !curl -i -X DELETE http://$target_host:$target_port/api/users/1
    ?HTTP/1.1 200 OK
    ?Content-Type: application/json
    ?{"message":"User deleted successfully"

# Test nested routes - GET user posts
[shell test_get_user_posts]
    !curl -i -X GET http://$target_host:$target_port/api/users/1/posts
    ?HTTP/1.1 200 OK
    ?Content-Type: application/json
    ?{"user_id":"1","posts":

# Test nested routes - POST user post
[shell test_create_user_post]
    !curl -i -X POST \
    !     -H "Content-Type: application/json" \
    !     -d '{"title":"Test Post","content":"Test Content"}' \
    !     http://$target_host:$target_port/api/users/1/posts
    ?HTTP/1.1 200 OK
    ?Content-Type: application/json
    ?{"message":"Post created successfully"

# Test CORS middleware
[shell test_cors]
    !curl -i -X OPTIONS \
    !     -H "Origin: http://example.com" \
    !     -H "Access-Control-Request-Method: POST" \
    !     http://$target_host:$target_port/api/users
    ?HTTP/1.1 200 OK
    ?Access-Control-Allow-Origin: \*
    ?Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS

# Test rate limiting middleware
[shell test_rate_limit]
    # Function to make repeated requests
    !for i in {1..101}; do \
    !    response=$(curl -s -w "%{http_code}" http://$target_host:$target_port/api/users); \
    !    if [ "$response" = "429" ]; then \
    !        echo "Rate limit reached successfully"; \
    !        break; \
    !    fi \
    !done
    ?Rate limit reached successfully

# Test validation middleware - missing user ID
[shell test_validation]
    !curl -i -X GET http://$target_host:$target_port/api/users//posts
    ?HTTP/1.1 400 Bad Request
    ?Content-Type: application/json
    ?{"error":"User ID is required"

[shell start_server]
    !init:stop().

[cleanup]
